# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Google Sheets CRM
GOOGLE_SERVICE_ACCOUNT_PATH=.secrets/sa.json
SHEET_ID=

# Discovery v2 (Phase 2) — Google Jobs aggregator + SMB enrichment
# Reused from the icp-agent Vercel project.
SERPAPI_API_KEY=
HUNTER_API_KEY=

# Scout Phase A - gated application sender (src/cv_tailor/sender.py)
# SMTP identity used to send job applications (smtp.gmail.com:587 STARTTLS).
APPLY_SMTP_USER=you@example.com
# Gmail app password for the address above (never the account password).
APPLY_SMTP_PASSWORD=
# "1" arms real sends to the job's apply_target; anything else (default "0")
# is unarmed and previews every send to APPLY_SMTP_USER's own inbox instead.
APPLY_ARMED=0
# Max armed sends per calendar day, counted from the applications ledger.
APPLY_DAILY_CAP=10
